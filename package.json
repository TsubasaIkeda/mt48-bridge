{
  "name": "mt48-osc-bridge",
  "version": "0.2.0",
  "description": "Neumann MT48 CometD -> OSC bridge for Max/MSP integration",
  "type": "module",
  "main": "dist/bridge.js",
  "scripts": {
    "dev": "vite-node src/main.ts",
    "build": "vite build",
    "start": "node dist/bridge.js",
    "discover": "vite-node src/discover-cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "cometd": "^9.0.1",
    "cometd-nodejs-client": "^2.0.0",
    "osc-min": "^2.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vite": "^8.1.4",
    "vite-node": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
